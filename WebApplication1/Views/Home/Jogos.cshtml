@{
    ViewBag.Title = "Jogos Cognitivos";
}

<style>
    h2 {
        color: #1a6b8a;
        font-size: 2rem;
        margin-bottom: 8px;
    }

    .subtitulo {
        color: #888;
        margin-bottom: 35px;
    }

    .jogos-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 25px;
    }

    .jogo-card {
        background: white;
        border-radius: 16px;
        padding: 30px;
        text-align: center;
        box-shadow: 0 4px 15px rgba(0,0,0,0.08);
        transition: transform 0.2s;
    }

        .jogo-card:hover {
            transform: translateY(-5px);
        }

    .jogo-icon {
        font-size: 4rem;
        margin-bottom: 15px;
    }

    .jogo-card h3 {
        color: #1a6b8a;
        font-size: 1.2rem;
        margin-bottom: 8px;
    }

    .jogo-card p {
        color: #666;
        font-size: 0.9rem;
        line-height: 1.5;
        margin-bottom: 15px;
    }

    .nivel {
        font-size: 0.8rem;
        font-weight: 700;
        padding: 4px 14px;
        border-radius: 20px;
        display: inline-block;
        margin-bottom: 15px;
    }

    .facil {
        background: #d4f5e2;
        color: #27ae60;
    }

    .medio {
        background: #fef3cd;
        color: #e67e00;
    }

    .btn-jogar {
        background: linear-gradient(135deg, #1a6b8a, #2ecc71);
        color: white;
        padding: 10px 28px;
        border-radius: 25px;
        text-decoration: none;
        font-weight: 700;
        display: inline-block;
        transition: opacity 0.2s;
    }

        .btn-jogar:hover {
            opacity: 0.9;
            color: white;
        }
</style>

<h2>🎮 Jogos para Estimulação Cognitiva</h2>
<p class="subtitulo">Atividades lúdicas que exercitam memória, atenção e raciocínio</p>

<div class="jogos-grid">
    <div class="jogo-card">
        <div class="jogo-icon">🃏</div>
        <h3>Jogo da Memória</h3>
        <span class="nivel facil">Fácil</span>
        <p>Encontre os pares de cartas e exercite sua memória de curto prazo de forma divertida.</p>
        <a href="#" class="btn-jogar">▶ Jogar</a>
    </div>
    <div class="jogo-card">
        <div class="jogo-icon">🔢</div>
        <h3>Sequência Numérica</h3>
        <span class="nivel medio">Médio</span>
        <p>Complete sequências de números e treine o raciocínio lógico e a atenção.</p>
        <a href="#" class="btn-jogar">▶ Jogar</a>
    </div>
    <div class="jogo-card">
        <div class="jogo-icon">🔤</div>
        <h3>Palavras Cruzadas</h3>
        <span class="nivel medio">Médio</span>
        <p>Resolva palavras cruzadas com temas do cotidiano para estimular o vocabulário.</p>
        <a href="#" class="btn-jogar">▶ Jogar</a>
    </div>
    <div class="jogo-card">
        <div class="jogo-icon">🎨</div>
        <h3>Identifique as Diferenças</h3>
        <span class="nivel facil">Fácil</span>
        <p>Compare duas imagens e encontre as diferenças. Ótimo para atenção e percepção visual.</p>
        <a href="#" class="btn-jogar">▶ Jogar</a>
    </div>
</div>